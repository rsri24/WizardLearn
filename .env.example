# ============================================
# WizardLearn — Environment Variables
# Copy this to .env and fill in your values
# ============================================

# Server
NODE_ENV=development
PORT=3000

# MongoDB — get free cluster at mongodb.com/atlas
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/wizardlearn?retryWrites=true&w=majority

# JWT Secret — any long random string (32+ chars)
JWT_SECRET=change_this_to_a_very_long_random_secret_string_at_least_32_chars
JWT_EXPIRES_IN=7d

# Email — for OTP sending (use Gmail app password or SendGrid)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=WizardLearn <your_gmail@gmail.com>

# ── QuestionGenerator Tool (https://github.com/rsri24/QuestionGenerator) ──────
# URL where your QuestionGenerator server.js is running
# Local dev: http://localhost:3001
# Deployed:  https://your-qg-app.vercel.app
QUESTION_GENERATOR_URL=http://localhost:3001

# Optional bearer token if you add auth to the QuestionGenerator server
QUESTION_GENERATOR_KEY=

# Timeout in ms for calls to QuestionGenerator (default 15000)
QG_TIMEOUT_MS=15000

# ── Admin secret (for /api/admin/* routes) ────────────────────────────────────
ADMIN_SECRET=change_this_to_a_secret_admin_token

# OTP settings
OTP_EXPIRES_MINUTES=10

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
